# 复制为 .env 后填写你的配置
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o-mini
# 可选：桌面端模型下拉列表，逗号分隔，默认会补充常用 OpenAI / DeepSeek 选项
# MODEL_OPTIONS=openai/gpt-4o-mini,deepseek/deepseek-chat,deepseek/deepseek-reasoner
# 可选：默认思考程度，支持 off / low / medium / high；off 时不会向模型请求传 reasoning_effort
# REASONING_EFFORT=off
# 可选：对话标题使用的低成本模型，默认继承 MODEL_PROVIDER / MODEL_NAME
# TITLE_MODEL_PROVIDER=openai
# TITLE_MODEL_NAME=gpt-4o-mini
# 可选：某些服务商需要显式配置
# OPENAI_API_BASE=
# 可选：阶段 2 的 web_fetch 默认关闭
# ENABLE_WEB_FETCH=true
